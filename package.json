{
  "name": "dropshipping-store",
  "version": "1.0.0",
  "description": "Modern dropshipping website with Next.js, TypeScript, Tailwind CSS, and Stripe integration",
  "private": true,
  "main": "electron-main.js",
  "scripts": {
    "dev": "next dev",
    "desktop": "electron .",
    "desktop:build": "electron-builder",
    "build": "next build",
    "test": "jest",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.1.6",
    "next-auth": "^4.24.0",
    "nodemailer": "^7.0.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stripe": "^14.7.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "29.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "autoprefixer": "^10.4.17",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.0",
    "jest": "29.0.0",
    "postcss": "^8.4.32",
    "prisma": "^5.7.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "29.0.0",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.ownbazar.desktop",
    "productName": "Own Bazar Desktop",
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "login.html",
      "index.html",
      "products-login.html",
      "products-list.html",
      "products-add.html",
      "products-detail.html",
      "desktop-config.json",
      "data/**",
      "node_modules/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    }
  }
}
