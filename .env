# Local environment variables for development
# IMPORTANT: keep this file secret and do not commit it to version control.

# Admin secret used to unlock the admin product page
ADMIN_SECRET=Don't Chase me i'll kill you
NEXT_PUBLIC_ADMIN_SECRET=Don't Chase me i'll kill you

# Database (optional - only needed if you wire Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/dropshipping_store"

# Stripe (optional placeholders)
